<!-- ============================================
     Property Locations Widget — HTML Template
     ============================================
     Layout: Left sidebar (PL summary + field sections) + Right panel (PDF Viewer)
     Top action buttons (Refer, Save Changes, Re-Run Geocoding) intentionally omitted.
     ============================================ -->

<link rel="preconnect" href="https://fonts.gstatic.com/" crossorigin="" />
<link rel="stylesheet"
  href="https://fonts.googleapis.com/css2?display=swap&family=Segoe+UI:wght@300;400;600;700&family=Inter:wght@400;500;600;700" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<div class="pdf-viewer-container">

  <!-- Loading overlay -->
  <div class="loading-overlay" ng-show="c.isLoading">
    <div class="loader-container">
      <div class="spinner"></div>
      <p class="loading-text">{{c.loadingMessage}}</p>
    </div>
  </div>

  <!-- Toast notifications -->
  <div class="toast-container" role="region" aria-label="Notifications" aria-live="assertive">
    <div class="toast" ng-repeat="toast in c.toasts track by toast.id" role="alert"
      ng-class="{'toast-success': toast.type === 'success', 'toast-error': toast.type === 'error', 'toast-info': toast.type === 'info', 'toast-warning': toast.type === 'warning'}">
      <div class="toast-icon">
        <i class="fas" aria-hidden="true" ng-class="{
          'fa-check-circle': toast.type === 'success',
          'fa-exclamation-circle': toast.type === 'error',
          'fa-info-circle': toast.type === 'info',
          'fa-exclamation-triangle': toast.type === 'warning'
        }"></i>
      </div>
      <div class="toast-content">
        <span class="toast-message">{{toast.message}}</span>
      </div>
      <button class="toast-close" ng-click="c.dismissToast(toast.id)" aria-label="Dismiss notification">
        <i class="fas fa-times" aria-hidden="true"></i>
      </button>
    </div>
  </div>

  <!-- ============================================
       MAIN LAYOUT — sidebar + PDF panel
       ============================================ -->
  <div class="main-layout">

    <!-- ============================================
         LEFT SIDEBAR
         ============================================ -->
    <div class="left-sidebar" ng-class="{'collapsed': c.sidebarCollapsed}"
      role="region" aria-label="Submission fields">

      <!-- Sidebar header: collapse toggle + Submission ID title -->
      <div class="fields-header">
        <div class="header-row">
          <div class="header-title-group">
            <button class="btn-collapse-toggle" ng-click="c.toggleSidebar()"
              aria-expanded="{{!c.sidebarCollapsed}}"
              aria-label="{{c.sidebarCollapsed ? 'Expand sidebar' : 'Collapse sidebar'}}"
              title="{{c.sidebarCollapsed ? 'Expand sidebar' : 'Collapse sidebar'}}">
              <i class="fas" ng-class="c.sidebarCollapsed ? 'fa-chevron-right' : 'fa-chevron-left'" aria-hidden="true"></i>
            </button>
            <h2 class="fields-title" ng-hide="c.sidebarCollapsed">
              Submission ID:
              <span class="submission-id-value">{{c.submission.number || '-'}}</span>
            </h2>
          </div>

          <!-- Top-right action button: Complete (AUDIT2MODEL for the URL's location). -->
          <div class="header-actions" ng-hide="c.sidebarCollapsed">
            <button class="btn-complete" ng-class="c.completeBtn.css"
              ng-click="c.markAsComplete()"
              ng-disabled="c.isLoading || c.completeBtn.disabled || c.hasValidationErrors()"
              title="{{c.hasValidationErrors() ? 'Commentary is required where QA Override is set' : ''}}">
              <span class="btn-complete-content">
                <!-- Bouncing dots for progress -->
                <span class="btn-progress-dots" ng-if="c.completeBtn.showDots">
                  <span class="dot"></span><span class="dot"></span><span class="dot"></span>
                </span>
                <!-- Animated circle-check for done -->
                <svg ng-if="c.completeBtn.showCheck" class="circle-check" viewBox="0 0 26 26" xmlns="http://www.w3.org/2000/svg">
                  <circle class="circle-check-ring" cx="13" cy="13" r="11" fill="none" stroke="#fff" stroke-width="2"/>
                  <path class="circle-check-tick" fill="none" stroke="#fff" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" d="M7.5 13.5 11 17 18.5 9.5"/>
                </svg>
                <!-- FA icon for idle / error -->
                <i class="fas {{c.completeBtn.icon}}" ng-if="!c.completeBtn.showDots && !c.completeBtn.showCheck && c.completeBtn.icon"></i>
                {{c.completeBtn.label}}
              </span>
            </button>
          </div>
        </div>

        <!-- Fields toolbar: document badge + search + Show only exceptions -->
        <div class="document-selector-row" ng-class="{'search-expanded': c.searchExpanded}">
          <span class="fields-label">Fields</span>
          <span class="doc-filter-pill" ng-show="c.currentDocumentLabel()">
            {{c.getVisibleFieldCount()}} of {{c.getTotalCount()}} ({{c.currentDocumentLabel()}})
          </span>

          <div class="search-inline" ng-show="c.searchExpanded">
            <i class="fas fa-search search-icon" aria-hidden="true"></i>
            <input type="text" ng-model="c.fieldSearch" placeholder="Search fields..."
              class="search-input" id="fieldSearchInput" aria-label="Search fields"
              ng-keydown="$event.keyCode === 27 && c.collapseSearch()">
            <button class="btn-search-clear" ng-click="c.collapseSearch()" aria-label="Close search" title="Close search">
              <i class="fas fa-times" aria-hidden="true"></i>
            </button>
          </div>
          <button class="btn-search-toggle" ng-click="c.expandSearch()"
            ng-show="!c.searchExpanded" aria-label="Search fields" title="Search fields">
            <i class="fas fa-search" aria-hidden="true"></i>
          </button>
        </div>
      </div>

      <!-- ============================================
           SIDEBAR CONTENT
           1. Property locations summary table (real)
           2. Collapsible field sections (dummy data for selected location)
           ============================================ -->
      <div class="fields-content">

        <!-- Property locations summary table -->
        <div class="pl-summary-wrapper" ng-show="c.propertyLocations.length">
          <table class="pl-summary-table">
            <thead>
              <tr>
                <th>Location Name</th>
                <th>Address</th>
                <th>Location Type</th>
                <th>Geocodes</th>
                <th>Line of Business</th>
                <th>State</th>
                <th>Country</th>
                <th>Insured Value</th>
              </tr>
            </thead>
            <tbody>
              <tr ng-repeat="loc in c.propertyLocations track by loc.sys_id"
                ng-click="c.selectPropertyLocation(loc)"
                ng-keydown="c.isActivateKey($event) && c.selectPropertyLocation(loc)"
                tabindex="0" role="row" aria-selected="{{c.isLocationSelected(loc)}}"
                aria-label="Property location {{loc.location_name}}, press Enter to select"
                ng-class="{'selected-pl': c.isLocationSelected(loc)}">
                <td title="{{loc.location_name}}">{{loc.location_name || '-'}}</td>
                <td title="{{loc.address_text}}">{{c.truncateText(loc.address_text, 35) || '-'}}</td>
                <td>{{loc.location_type || '-'}}</td>
                <td>{{loc.geocodes || '-'}}</td>
                <td>{{loc.line_of_business || '-'}}</td>
                <td>{{loc.state || '-'}}</td>
                <td>{{loc.country || '-'}}</td>
                <td>{{loc.insured_value || '-'}}</td>
              </tr>
            </tbody>
          </table>
        </div>

        <!-- ============================================
             MODEL DATA area — existing field sections (coverage metadata + property_coverage).
             Independently collapsible via c.modelDataCollapsed.
             ============================================ -->
        <div class="field-area">
          <div class="area-header" role="button" tabindex="0" aria-expanded="{{!c.modelDataCollapsed}}"
            aria-controls="modelDataBody" ng-click="c.toggleModelData()"
            ng-keydown="c.isActivateKey($event) && c.toggleModelData()">
            <i class="fas area-chevron" ng-class="c.modelDataCollapsed ? 'fa-chevron-right' : 'fa-chevron-down'" aria-hidden="true"></i>
            <span class="area-title">Model Data</span>
          </div>

          <div class="field-area-body" id="modelDataBody" ng-show="!c.modelDataCollapsed">
        <!-- Collapsible field sections — c.groupedFields is an ordered array [{key,label,fields}] -->
        <div ng-repeat="section in c.groupedFields track by section.key" class="field-section">

          <div class="section-header" role="button" tabindex="0"
            aria-expanded="{{!c.collapsedSections[section.key]}}"
            aria-label="{{section.label}} section, {{section.fields.length}} fields"
            ng-click="c.collapsedSections[section.key] = !c.collapsedSections[section.key]"
            ng-keydown="c.isActivateKey($event) && (c.collapsedSections[section.key] = !c.collapsedSections[section.key])">
            <div class="section-title-wrapper">
              <i class="fas" ng-class="c.collapsedSections[section.key] ? 'fa-chevron-right' : 'fa-chevron-down'" aria-hidden="true"></i>
              <span class="section-title">{{section.label}} ({{section.fields.length}})</span>
            </div>
            <div class="section-accuracy" ng-if="section.fields.length > 0 && c.sectionHasConfidence(section.fields)"
              ng-class="c.getSectionAccuracyClass(section.fields)">
              {{c.calculateSectionAccuracy(section.fields) | number:2}}%
            </div>
          </div>

          <div class="section-table-wrapper" ng-show="!c.collapsedSections[section.key]">
            <table class="fields-table">
              <thead>
                <tr>
                  <th class="col-field-name">Field Name</th>
                  <th class="col-ai-value">AI Value</th>
                  <th class="col-data-verification">Data Verification</th>
                  <th class="col-logic">Logic Transparency</th>
                  <th class="col-commentary">Commentary</th>
                </tr>
              </thead>
              <tbody>
                <tr ng-repeat="field in section.fields | filter:c.searchFilter" ng-if="c.shouldShowField(field)"
                  ng-click="c.canNavigate(field) && c.navigateToField(field)"
                  ng-keydown="c.canNavigate(field) && c.isActivateKey($event) && c.navigateToField(field)"
                  tabindex="{{c.canNavigate(field) ? 0 : -1}}"
                  role="row" aria-selected="{{c.isActiveField(field)}}"
                  aria-label="{{field.field_name}}{{c.canNavigate(field) ? ', press Enter to locate in document' : ''}}"
                  ng-class="{'no-navigate': !c.canNavigate(field), 'has-validation-error': field.validationError, 'active-field': c.isActiveField(field)}">

                  <td class="col-field-name">
                    <div class="field-name-cell">
                      <span class="field-name" title="{{field.field_name}}">{{field.field_name}}</span>
                      <span class="confidence-pill" ng-if="c.hasConfidenceValue(field.confidence_indicator)"
                        ng-class="c.getConfidencePillClass(field.confidence_indicator)">
                        {{field.confidence_indicator * 100 | number:2}}%
                      </span>
                    </div>
                  </td>

                  <!-- AI Value — click-to-edit. Boolean → Yes/No select, else text input.
                       Editable only when a coverage value row exists (field.meta.sysId). -->
                  <td class="col-ai-value" ng-click="$event.stopPropagation()">
                    <select ng-if="c.isEditing(field, 'value') && c.isBooleanField(field)"
                      id="cellEditor-{{field.sys_id}}-value" class="ai-value-input"
                      ng-model="field.field_value"
                      ng-change="c.markFieldAsChanged(field)"
                      ng-blur="c.stopEditing(field, 'value')">
                      <option value="">-</option>
                      <option value="true">Yes</option>
                      <option value="false">No</option>
                    </select>
                    <input ng-if="c.isEditing(field, 'value') && !c.isBooleanField(field)" type="text"
                      id="cellEditor-{{field.sys_id}}-value" class="ai-value-input"
                      ng-model="field.field_value"
                      ng-change="c.markFieldAsChanged(field)"
                      ng-blur="c.stopEditing(field, 'value')"
                      ng-keydown="$event.keyCode === 13 && c.stopEditing(field, 'value')"
                      title="{{field.field_value}}" placeholder="-">

                    <div ng-if="!c.isEditing(field, 'value') && c.canEditColumn(field, 'value')"
                      class="ai-value-display editable"
                      ng-click="c.startEditing(field, 'value', $event)" title="Click to edit">
                      <span class="cell-text" ng-class="{'has-value': field.field_value}">
                        {{c.truncateText(c.displayText(field, 'value'), 18) || '-'}}
                      </span>
                      <i class="fas fa-pen ai-value-edit-icon"></i>
                    </div>

                    <span ng-if="!c.isEditing(field, 'value') && !c.canEditColumn(field, 'value')"
                      class="cell-text" ng-class="{'has-value': field.field_value}"
                      title="{{c.displayText(field, 'value')}}">
                      {{c.truncateText(c.displayText(field, 'value'), 18) || '-'}}
                    </span>
                  </td>

                  <!-- Data Verification — click-to-edit (UI only; no backing column yet). -->
                  <td class="col-data-verification" ng-click="$event.stopPropagation()">
                    <input ng-if="c.isEditing(field, 'verification')" type="text"
                      id="cellEditor-{{field.sys_id}}-verification" class="verification-input"
                      ng-model="field.data_verification"
                      ng-change="c.markFieldAsChanged(field)"
                      ng-blur="c.stopEditing(field, 'verification')"
                      ng-keydown="$event.keyCode === 13 && c.stopEditing(field, 'verification')"
                      title="{{field.data_verification}}" placeholder="Override value">

                    <div ng-if="!c.isEditing(field, 'verification')"
                      class="ai-value-display editable"
                      ng-click="c.startEditing(field, 'verification', $event)" title="Click to edit">
                      <span class="cell-text" ng-class="{'has-value': field.data_verification}">
                        {{c.truncateText(c.displayText(field, 'verification'), 18) || '-'}}
                      </span>
                      <i class="fas fa-pen ai-value-edit-icon"></i>
                    </div>
                  </td>

                  <td class="col-logic">
                    <span class="cell-text" ng-class="{'has-value': field.logic_transparency}"
                      title="{{field.logic_transparency}}">
                      {{c.truncateText(field.logic_transparency, 18) || '-'}}
                    </span>
                  </td>

                  <!-- Commentary — click-to-edit (UI only; no backing column yet). -->
                  <td class="col-commentary" ng-click="$event.stopPropagation()">
                    <input ng-if="c.isEditing(field, 'commentary')" type="text"
                      id="cellEditor-{{field.sys_id}}-commentary" class="commentary-input"
                      ng-model="field.commentary"
                      ng-change="c.markFieldAsChanged(field)"
                      ng-blur="c.stopEditing(field, 'commentary')"
                      ng-keydown="$event.keyCode === 13 && c.stopEditing(field, 'commentary')"
                      title="{{field.commentary}}" placeholder="Override value">

                    <div ng-if="!c.isEditing(field, 'commentary')"
                      class="ai-value-display editable"
                      ng-click="c.startEditing(field, 'commentary', $event)" title="Click to edit">
                      <span class="cell-text" ng-class="{'has-value': field.commentary}">
                        {{c.truncateText(c.displayText(field, 'commentary'), 18) || '-'}}
                      </span>
                      <i class="fas fa-pen ai-value-edit-icon"></i>
                    </div>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
          </div><!-- /.field-area-body (Model Data) -->
        </div><!-- /.field-area (Model Data) -->

        <!-- ============================================
             AUDIT DATA area — line items from x_gegis_uwm_dashbo_data_extraction_lineitem,
             scoped per PL by model_object_sys_id. Same 5-column table as Model Data, but all
             three editable columns (AI Value / Data Verification / Commentary) persist to the
             line item row. Independently collapsible via c.auditDataCollapsed.
             ============================================ -->
        <div class="field-area field-area--audit" ng-if="c.auditGroupedFields.length">
          <div class="area-header" role="button" tabindex="0" aria-expanded="{{!c.auditDataCollapsed}}"
            aria-controls="auditDataBody" ng-click="c.toggleAuditData()"
            ng-keydown="c.isActivateKey($event) && c.toggleAuditData()">
            <i class="fas area-chevron" ng-class="c.auditDataCollapsed ? 'fa-chevron-right' : 'fa-chevron-down'" aria-hidden="true"></i>
            <span class="area-title">Audit Data</span>
          </div>

          <div class="field-area-body" id="auditDataBody" ng-show="!c.auditDataCollapsed">
            <div ng-repeat="section in c.auditGroupedFields track by section.key" class="field-section">

              <div class="section-header" role="button" tabindex="0"
                aria-expanded="{{!c.auditCollapsedSections[section.key]}}"
                aria-label="{{section.label}} section, {{section.fields.length}} fields"
                ng-click="c.auditCollapsedSections[section.key] = !c.auditCollapsedSections[section.key]"
                ng-keydown="c.isActivateKey($event) && (c.auditCollapsedSections[section.key] = !c.auditCollapsedSections[section.key])">
                <div class="section-title-wrapper">
                  <i class="fas" ng-class="c.auditCollapsedSections[section.key] ? 'fa-chevron-right' : 'fa-chevron-down'" aria-hidden="true"></i>
                  <span class="section-title">{{section.label}} ({{section.fields.length}})</span>
                </div>
                <div class="section-accuracy" ng-if="section.fields.length > 0 && c.sectionHasConfidence(section.fields)"
                  ng-class="c.getSectionAccuracyClass(section.fields)">
                  {{c.calculateSectionAccuracy(section.fields) | number:2}}%
                </div>
              </div>

              <div class="section-table-wrapper" ng-show="!c.auditCollapsedSections[section.key]">
                <table class="fields-table">
                  <thead>
                    <tr>
                      <th class="col-field-name">Field Name</th>
                      <th class="col-ai-value">AI Value</th>
                      <th class="col-data-verification">Data Verification</th>
                      <th class="col-qa-override">QA Override</th>
                      <th class="col-logic">Logic Transparency</th>
                      <th class="col-commentary">Commentary</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr ng-repeat="field in section.fields | filter:c.searchFilter" ng-if="c.shouldShowField(field)"
                      ng-click="c.canNavigate(field) && c.navigateToField(field)"
                      ng-keydown="c.canNavigate(field) && c.isActivateKey($event) && c.navigateToField(field)"
                      tabindex="{{c.canNavigate(field) ? 0 : -1}}"
                      role="row" aria-selected="{{c.isActiveField(field)}}"
                      aria-label="{{field.field_name}}{{c.canNavigate(field) ? ', press Enter to locate in document' : ''}}"
                      ng-class="{'no-navigate': !c.canNavigate(field), 'has-validation-error': field.validationError, 'active-field': c.isActiveField(field)}">

                      <td class="col-field-name">
                        <div class="field-name-cell">
                          <span class="field-name" title="{{field.field_name}}">{{field.field_name}}</span>
                          <span class="confidence-pill" ng-if="c.hasConfidenceValue(field.confidence_indicator)"
                            ng-class="c.getConfidencePillClass(field.confidence_indicator)">
                            {{field.confidence_indicator * 100 | number:2}}%
                          </span>
                        </div>
                      </td>

                      <!-- AI Value — READ-ONLY for Audit Data (never editable). -->
                      <td class="col-ai-value">
                        <span class="cell-text" ng-class="{'has-value': field.field_value}"
                          title="{{c.displayText(field, 'value')}}">
                          {{c.truncateText(c.displayText(field, 'value'), 18) || '-'}}
                        </span>
                      </td>

                      <!-- Data Verification — click-to-edit when submission status permits; else read-only text. -->
                      <td class="col-data-verification" ng-click="$event.stopPropagation()">
                        <input ng-if="c.isEditing(field, 'verification')" type="text"
                          id="cellEditor-{{field.sys_id}}-verification" class="verification-input"
                          ng-model="field.data_verification"
                          ng-change="c.markFieldAsChanged(field)"
                          ng-blur="c.stopEditing(field, 'verification')"
                          ng-keydown="$event.keyCode === 13 && c.stopEditing(field, 'verification')"
                          title="{{field.data_verification}}" placeholder="Override value">

                        <div ng-if="!c.isEditing(field, 'verification') && c.canEditColumn(field, 'verification')"
                          class="ai-value-display editable"
                          ng-click="c.startEditing(field, 'verification', $event)" title="Click to edit">
                          <span class="cell-text" ng-class="{'has-value': field.data_verification}">
                            {{c.truncateText(c.displayText(field, 'verification'), 18) || '-'}}
                          </span>
                          <i class="fas fa-pen ai-value-edit-icon"></i>
                        </div>

                        <span ng-if="!c.isEditing(field, 'verification') && !c.canEditColumn(field, 'verification')"
                          class="cell-text" ng-class="{'has-value': field.data_verification}"
                          title="{{c.displayText(field, 'verification')}}">
                          {{c.truncateText(c.displayText(field, 'verification'), 18) || '-'}}
                        </span>
                      </td>

                      <!-- QA Override — click-to-edit when submission status permits; else read-only text.
                           Setting a value makes Commentary mandatory (see markAsComplete / autoSaveField). -->
                      <td class="col-qa-override" ng-click="$event.stopPropagation()">
                        <input ng-if="c.isEditing(field, 'qaOverride')" type="text"
                          id="cellEditor-{{field.sys_id}}-qaOverride" class="override-input"
                          ng-model="field.qa_override_value"
                          ng-change="c.markFieldAsChanged(field)"
                          ng-blur="c.stopEditing(field, 'qaOverride')"
                          ng-keydown="$event.keyCode === 13 && c.stopEditing(field, 'qaOverride')"
                          title="{{field.qa_override_value}}" placeholder="Override value">

                        <div ng-if="!c.isEditing(field, 'qaOverride') && c.canEditColumn(field, 'qaOverride')"
                          class="ai-value-display editable"
                          ng-click="c.startEditing(field, 'qaOverride', $event)" title="Click to edit">
                          <span class="cell-text" ng-class="{'has-value': field.qa_override_value}">
                            {{c.truncateText(c.displayText(field, 'qaOverride'), 18) || '-'}}
                          </span>
                          <i class="fas fa-pen ai-value-edit-icon"></i>
                        </div>

                        <span ng-if="!c.isEditing(field, 'qaOverride') && !c.canEditColumn(field, 'qaOverride')"
                          class="cell-text" ng-class="{'has-value': field.qa_override_value}"
                          title="{{c.displayText(field, 'qaOverride')}}">
                          {{c.truncateText(c.displayText(field, 'qaOverride'), 18) || '-'}}
                        </span>
                      </td>

                      <td class="col-logic">
                        <span class="cell-text" ng-class="{'has-value': field.logic_transparency}"
                          title="{{field.logic_transparency}}">
                          {{c.truncateText(field.logic_transparency, 18) || '-'}}
                        </span>
                      </td>

                      <!-- Commentary — click-to-edit when submission status permits; else read-only text.
                           Mandatory (red highlight) when QA Override is set: field.commentaryRequired. -->
                      <td class="col-commentary" ng-click="$event.stopPropagation()">
                        <input ng-if="c.isEditing(field, 'commentary')" type="text"
                          id="cellEditor-{{field.sys_id}}-commentary" class="commentary-input"
                          ng-class="{'validation-error': field.commentaryRequired}"
                          ng-model="field.commentary"
                          ng-change="c.markFieldAsChanged(field); field.commentaryRequired = false;"
                          ng-blur="c.stopEditing(field, 'commentary')"
                          ng-keydown="$event.keyCode === 13 && c.stopEditing(field, 'commentary')"
                          title="{{field.commentary}}" placeholder="Required for QA Override">

                        <div ng-if="!c.isEditing(field, 'commentary') && c.canEditColumn(field, 'commentary')"
                          class="ai-value-display editable"
                          ng-class="{'commentary-required': field.commentaryRequired}"
                          ng-click="c.startEditing(field, 'commentary', $event)" title="Click to edit">
                          <span class="cell-text" ng-class="{'has-value': field.commentary}">
                            {{c.truncateText(c.displayText(field, 'commentary'), 18) || '-'}}
                          </span>
                          <i class="fas fa-pen ai-value-edit-icon"></i>
                        </div>

                        <span ng-if="!c.isEditing(field, 'commentary') && !c.canEditColumn(field, 'commentary')"
                          class="cell-text" ng-class="{'has-value': field.commentary}"
                          title="{{c.displayText(field, 'commentary')}}">
                          {{c.truncateText(c.displayText(field, 'commentary'), 18) || '-'}}
                        </span>
                      </td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div><!-- /.field-area-body (Audit Data) -->
        </div><!-- /.field-area (Audit Data) -->

        <!-- Empty state -->
        <div class="empty-state"
          ng-if="!c.isLoading && (!c.propertyLocations || c.propertyLocations.length === 0)">
          <i class="fas fa-map-marker-alt empty-icon"></i>
          <p class="empty-title">No Property Locations</p>
          <p class="empty-hint">No property location records found for this submission.</p>
        </div>
      </div>

      <!-- Save status bar -->
      <div class="save-status-bar" role="status" aria-live="polite"
        ng-class="{'saving': c.saveStatus === 'saving', 'saved': c.saveStatus === 'saved', 'error': c.saveStatus === 'error'}"
        ng-show="c.saveStatus">
        <i class="fas fa-spinner fa-spin" ng-show="c.saveStatus === 'saving'" aria-hidden="true"></i>
        <i class="fas fa-check-circle" ng-show="c.saveStatus === 'saved'" aria-hidden="true"></i>
        <i class="fas fa-exclamation-circle" ng-show="c.saveStatus === 'error'" aria-hidden="true"></i>
        <span>{{c.saveStatusMessage}}</span>
      </div>
    </div>

    <!-- ============================================
         RIGHT PANEL — PDF VIEWER
         ============================================ -->
    <div class="pdf-panel" role="region" aria-label="Source document viewer">

      <div class="pdf-header">
        <!-- Left cluster: in Excel mode a sheet prev/next + "Sheet i / n"; then filename. -->
        <div class="pdf-title">
          <div class="control-group excel-sheet-nav" ng-if="c.activeDocType === 'excel' && c.excelSheetNames.length > 1">
            <button ng-click="c.excelPrevSheet()" ng-disabled="c.excelSheetIndex <= 1" class="btn-icon" aria-label="Previous sheet" title="Previous Sheet">
              <i class="fas fa-chevron-left" aria-hidden="true"></i>
            </button>
            <span class="page-info excel-sheet-label" title="{{c.excelActiveSheet}}" aria-live="polite">
              <span class="excel-sheet-name">{{c.excelActiveSheet}}</span>
              <span class="excel-sheet-count">{{c.excelSheetIndex}} / {{c.excelSheetNames.length}}</span>
            </span>
            <button ng-click="c.excelNextSheet()" ng-disabled="c.excelSheetIndex >= c.excelSheetNames.length" class="btn-icon" aria-label="Next sheet" title="Next Sheet">
              <i class="fas fa-chevron-right" aria-hidden="true"></i>
            </button>
          </div>
          <!-- Single-sheet workbook: still show the sheet name (no prev/next). -->
          <div class="control-group excel-sheet-nav" ng-if="c.activeDocType === 'excel' && c.excelSheetNames.length === 1">
            <span class="page-info excel-sheet-label" title="{{c.excelActiveSheet}}">
              <span class="excel-sheet-name">{{c.excelActiveSheet}}</span>
            </span>
          </div>
          <i class="fas" ng-class="c.activeDocType === 'excel' ? 'fa-file-excel excel-icon' : 'fa-file-pdf'" aria-hidden="true"></i>
          <span ng-if="c.activeDocType === 'excel'">{{c.excelFileName || c.excelActiveSheet || 'Spreadsheet'}}</span>
          <span ng-if="c.activeDocType !== 'excel' && c.currentDocumentLabel()">{{c.currentDocumentLabel()}}</span>
          <span ng-if="c.activeDocType !== 'excel' && !c.currentDocumentLabel()">No document selected</span>
        </div>

        <!-- PDF controls — only in PDF mode. -->
        <div class="pdf-controls" ng-if="c.activeDocType !== 'excel'" role="toolbar" aria-label="PDF controls">
          <div class="control-group">
            <button ng-click="c.fitWidth()" ng-disabled="c.isLoading || !c.pdfLoaded" class="btn-icon"
              ng-class="{'active': c.zoomMode === 'fit-width'}" aria-label="Fit to width"
              aria-pressed="{{c.zoomMode === 'fit-width'}}" title="Fit to Width">
              <i class="fa-solid fa-arrows-left-right-to-line" aria-hidden="true"></i>
            </button>
            <button ng-click="c.actual100Percent()" ng-disabled="c.isLoading || !c.pdfLoaded" class="btn-icon"
              ng-class="{'active': c.zoomMode === 'actual-size'}" aria-label="Actual size (100%)"
              aria-pressed="{{c.zoomMode === 'actual-size'}}" title="Actual Size (100%)">
              <i class="fa-solid fa-text-height" aria-hidden="true"></i>
            </button>
          </div>

          <div class="control-group">
            <button ng-click="c.previousPage()" ng-disabled="c.currentPage <= 1 || c.isLoading" class="btn-icon"
              aria-label="Previous page" title="Previous Page">
              <i class="fas fa-chevron-left" aria-hidden="true"></i>
            </button>
            <div class="page-info" aria-live="polite">
              <span>Page {{c.currentPage}} of {{c.totalPages}}</span>
            </div>
            <button ng-click="c.nextPage()" ng-disabled="c.currentPage >= c.totalPages || c.isLoading" class="btn-icon"
              aria-label="Next page" title="Next Page">
              <i class="fas fa-chevron-right" aria-hidden="true"></i>
            </button>
          </div>

          <div class="control-group">
            <button ng-click="c.downloadActiveDoc()" ng-disabled="!c.activeDownloadUrl" class="btn-icon"
              aria-label="Download document" title="Download document">
              <i class="fas fa-download" aria-hidden="true"></i>
            </button>
          </div>
        </div>

        <!-- Excel zoom + download controls — only in Excel mode. -->
        <div class="pdf-controls" ng-if="c.activeDocType === 'excel'" role="toolbar" aria-label="Spreadsheet controls">
          <div class="control-group">
            <button ng-click="c.excelZoomOut()" ng-disabled="!c.excelLoaded" class="btn-icon" aria-label="Zoom out" title="Zoom Out">
              <i class="fas fa-minus" aria-hidden="true"></i>
            </button>
            <span class="page-info" aria-live="polite" aria-label="Zoom {{c.excelScalePercent()}} percent">{{c.excelScalePercent()}}%</span>
            <button ng-click="c.excelZoomIn()" ng-disabled="!c.excelLoaded" class="btn-icon" aria-label="Zoom in" title="Zoom In">
              <i class="fas fa-plus" aria-hidden="true"></i>
            </button>
          </div>

          <div class="control-group">
            <button ng-click="c.excelZoomFit()" ng-disabled="!c.excelLoaded" class="btn-icon"
              ng-class="{'active': c.excelFit}" aria-label="Fit to width" aria-pressed="{{c.excelFit}}" title="Fit to Width">Fit</button>
          </div>

          <div class="control-group">
            <button ng-click="c.downloadActiveDoc()" ng-disabled="!c.activeDownloadUrl" class="btn-icon"
              aria-label="Download spreadsheet" title="Download spreadsheet">
              <i class="fas fa-download" aria-hidden="true"></i>
            </button>
          </div>
        </div>
      </div>

      <div class="pdf-content" id="pdfContainer">
        <div class="pdf-loading-overlay" ng-show="c.isPdfLoading" role="status" aria-live="polite">
          <div class="pdf-loader">
            <i class="fas fa-spinner fa-spin" aria-hidden="true"></i>
            <span>Loading {{c.activeDocType === 'excel' ? 'spreadsheet' : 'PDF'}}...</span>
          </div>
        </div>

        <div class="pdf-placeholder" ng-show="!c.pdfLoaded && !c.excelLoaded && !c.isPdfLoading">
          <div class="placeholder-content">
            <i class="fas fa-file-pdf placeholder-icon"></i>
            <h3 class="placeholder-title">No Document Available</h3>
            <p class="placeholder-text">Select a property location to view its document</p>
          </div>
        </div>

        <div class="pdf-canvas-wrapper" ng-show="c.pdfLoaded">
          <canvas id="pdfCanvas" class="pdf-canvas"></canvas>
          <canvas id="annotationCanvas" class="annotation-canvas"></canvas>
        </div>

        <!-- Excel grid — populated imperatively by renderSheet() in the controller. -->
        <div class="excel-content" id="excelContainer" ng-show="c.excelLoaded"
          role="table" aria-label="Spreadsheet {{c.excelFileName}} sheet {{c.excelActiveSheet}}"></div>
      </div>

      <div class="pdf-footer">
        <div class="footer-content">
          <span class="footer-item">
            <i class="fas fa-file"></i>
            A4: 595 × 842 points
          </span>
          <span class="footer-item">
            <i class="fas fa-expand"></i>
            Scale: {{(c.scale * 100) | number:0}}%
          </span>
          <span class="footer-item" ng-if="c.activeField">
            <i class="fas fa-crosshairs"></i>
            Active: {{c.activeField.field_name}}
          </span>
        </div>
      </div>
    </div>
  </div>
</div>
