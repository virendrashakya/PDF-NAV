<!-- ============================================
     Property Locations Widget — HTML Template
     ============================================
     Layout: Left sidebar (PL summary + field sections) + Right panel (PDF Viewer)
     Top action buttons (Refer, Save Changes, Re-Run Geocoding) intentionally omitted.
     ============================================ -->

<link rel="preconnect" href="https://fonts.gstatic.com/" crossorigin="" />
<link rel="stylesheet"
  href="https://fonts.googleapis.com/css2?display=swap&family=Segoe+UI:wght@300;400;600;700&family=Inter:wght@400;500;600;700" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<div class="pdf-viewer-container">

  <!-- Loading overlay -->
  <div class="loading-overlay" ng-show="c.isLoading">
    <div class="loader-container">
      <div class="spinner"></div>
      <p class="loading-text">{{c.loadingMessage}}</p>
    </div>
  </div>

  <!-- Toast notifications -->
  <div class="toast-container">
    <div class="toast" ng-repeat="toast in c.toasts track by toast.id"
      ng-class="{'toast-success': toast.type === 'success', 'toast-error': toast.type === 'error', 'toast-info': toast.type === 'info', 'toast-warning': toast.type === 'warning'}">
      <div class="toast-icon">
        <i class="fas" ng-class="{
          'fa-check-circle': toast.type === 'success',
          'fa-exclamation-circle': toast.type === 'error',
          'fa-info-circle': toast.type === 'info',
          'fa-exclamation-triangle': toast.type === 'warning'
        }"></i>
      </div>
      <div class="toast-content">
        <span class="toast-message">{{toast.message}}</span>
      </div>
      <button class="toast-close" ng-click="c.dismissToast(toast.id)">
        <i class="fas fa-times"></i>
      </button>
    </div>
  </div>

  <!-- ============================================
       MAIN LAYOUT — sidebar + PDF panel
       ============================================ -->
  <div class="main-layout">

    <!-- ============================================
         LEFT SIDEBAR
         ============================================ -->
    <div class="left-sidebar" ng-class="{'collapsed': c.sidebarCollapsed}">

      <!-- Sidebar header: collapse toggle + Submission ID title -->
      <div class="fields-header">
        <div class="header-row">
          <div class="header-title-group">
            <button class="btn-collapse-toggle" ng-click="c.toggleSidebar()"
              title="{{c.sidebarCollapsed ? 'Expand sidebar' : 'Collapse sidebar'}}">
              <i class="fas" ng-class="c.sidebarCollapsed ? 'fa-chevron-right' : 'fa-chevron-left'"></i>
            </button>
            <h2 class="fields-title" ng-hide="c.sidebarCollapsed">
              Submission ID:
              <span class="submission-id-value">{{c.submission.number || '-'}}</span>
            </h2>
          </div>

          <!-- Top-right action buttons (dummy handlers for now) -->
          <div class="header-actions" ng-hide="c.sidebarCollapsed">
            <button class="btn-secondary" ng-click="c.onRefer()" title="Refer the submission">
              Refer
            </button>
            <button class="btn-secondary" ng-click="c.onSaveChanges()" title="Save all pending changes">
              Save Changes
            </button>
            <button class="btn-primary" ng-click="c.onReRunGeocoding()" title="Re-run geocoding for all property locations">
              Re-Run Geocoding
            </button>
          </div>
        </div>

        <!-- Fields toolbar: document badge + search + Show only exceptions -->
        <div class="document-selector-row" ng-class="{'search-expanded': c.searchExpanded}">
          <span class="fields-label">Fields</span>
          <span class="doc-filter-pill" ng-show="c.currentDocumentLabel()">
            {{c.getVisibleFieldCount()}} of {{c.getTotalCount()}} ({{c.currentDocumentLabel()}})
          </span>

          <div class="search-inline" ng-show="c.searchExpanded">
            <i class="fas fa-search search-icon"></i>
            <input type="text" ng-model="c.fieldSearch" placeholder="Search fields..."
              class="search-input" id="fieldSearchInput"
              ng-keydown="$event.keyCode === 27 && c.collapseSearch()">
            <button class="btn-search-clear" ng-click="c.collapseSearch()" title="Close search">
              <i class="fas fa-times"></i>
            </button>
          </div>
          <button class="btn-search-toggle" ng-click="c.expandSearch()"
            ng-show="!c.searchExpanded" title="Search fields">
            <i class="fas fa-search"></i>
          </button>

          <!-- Show only exceptions toggle -->
          <label class="exceptions-toggle" title="Show only fields with exceptions / low confidence">
            <input type="checkbox" ng-model="c.showOnlyExceptions">
            <span class="toggle-track"><span class="toggle-thumb"></span></span>
            <span class="toggle-label">Show only exceptions</span>
          </label>
        </div>
      </div>

      <!-- ============================================
           SIDEBAR CONTENT
           1. Property locations summary table (real)
           2. Collapsible field sections (dummy data for selected location)
           ============================================ -->
      <div class="fields-content">

        <!-- Property locations summary table -->
        <div class="pl-summary-wrapper" ng-show="c.propertyLocations.length">
          <table class="pl-summary-table">
            <thead>
              <tr>
                <th>Location Name</th>
                <th>Address</th>
                <th>Location Type</th>
                <th>Geocodes</th>
                <th>Line of Business</th>
                <th>State</th>
                <th>Country</th>
                <th>Insured Value</th>
              </tr>
            </thead>
            <tbody>
              <tr ng-repeat="loc in c.propertyLocations track by loc.sys_id"
                ng-click="c.selectPropertyLocation(loc)"
                ng-class="{'selected-pl': c.isLocationSelected(loc)}">
                <td title="{{loc.location_name}}">{{loc.location_name || '-'}}</td>
                <td title="{{loc.address_text}}">{{c.truncateText(loc.address_text, 35) || '-'}}</td>
                <td>{{loc.location_type || '-'}}</td>
                <td>{{loc.geocodes || '-'}}</td>
                <td>{{loc.line_of_business || '-'}}</td>
                <td>{{loc.state || '-'}}</td>
                <td>{{loc.country || '-'}}</td>
                <td>{{loc.insured_value || '-'}}</td>
              </tr>
            </tbody>
          </table>
        </div>

        <!-- Collapsible field sections (dummy for now) -->
        <div ng-repeat="(sectionName, fields) in c.groupedFields" class="field-section">

          <div class="section-header" ng-click="c.collapsedSections[sectionName] = !c.collapsedSections[sectionName]">
            <div class="section-title-wrapper">
              <i class="fas" ng-class="c.collapsedSections[sectionName] ? 'fa-chevron-right' : 'fa-chevron-down'"></i>
              <span class="section-title">{{sectionName}} ({{fields.length}})</span>
            </div>
            <div class="section-accuracy" ng-if="fields.length > 0 && c.sectionHasConfidence(fields)"
              ng-class="c.getSectionAccuracyClass(fields)">
              {{c.calculateSectionAccuracy(fields) | number:2}}%
            </div>
          </div>

          <div class="section-table-wrapper" ng-show="!c.collapsedSections[sectionName]">
            <table class="fields-table">
              <thead>
                <tr>
                  <th class="col-field-name">Field Name</th>
                  <th class="col-ai-value">AI Value</th>
                  <th class="col-data-verification">Data Verification</th>
                  <th class="col-logic">Logic Transparency</th>
                  <th class="col-commentary">Commentary</th>
                </tr>
              </thead>
              <tbody>
                <tr ng-repeat="field in fields | filter:c.searchFilter" ng-if="c.shouldShowField(field)"
                  ng-click="c.canNavigate(field) && c.navigateToField(field)"
                  ng-class="{'no-navigate': !c.canNavigate(field), 'has-validation-error': field.validationError}">

                  <td class="col-field-name">
                    <div class="field-name-cell">
                      <span class="field-name" title="{{field.field_name}}">{{field.field_name}}</span>
                      <span class="confidence-pill" ng-if="c.hasConfidenceValue(field.confidence_indicator)"
                        ng-class="c.getConfidencePillClass(field.confidence_indicator)">
                        {{field.confidence_indicator * 100 | number:2}}%
                      </span>
                    </div>
                  </td>

                  <td class="col-ai-value">
                    <span class="cell-text" ng-class="{'has-value': field.field_value}" title="{{field.field_value}}">
                      {{c.truncateText(field.field_value, 18) || '-'}}
                    </span>
                  </td>

                  <td class="col-data-verification" ng-click="$event.stopPropagation()">
                    <input type="text" class="verification-input" ng-model="field.data_verification"
                      ng-change="c.markFieldAsChanged(field)"
                      ng-blur="c.autoSaveField(field)" placeholder="Override value">
                  </td>

                  <td class="col-logic">
                    <span class="cell-text" ng-class="{'has-value': field.logic_transparency}"
                      title="{{field.logic_transparency}}">
                      {{c.truncateText(field.logic_transparency, 18) || '-'}}
                    </span>
                  </td>

                  <td class="col-commentary" ng-click="$event.stopPropagation()">
                    <input type="text" class="commentary-input" ng-model="field.commentary"
                      ng-change="c.markFieldAsChanged(field)"
                      ng-blur="c.autoSaveField(field)" placeholder="Override value">
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

        <!-- Empty state -->
        <div class="empty-state"
          ng-if="!c.isLoading && (!c.propertyLocations || c.propertyLocations.length === 0)">
          <i class="fas fa-map-marker-alt empty-icon"></i>
          <p class="empty-title">No Property Locations</p>
          <p class="empty-hint">No property location records found for this submission.</p>
        </div>
      </div>

      <!-- Save status bar -->
      <div class="save-status-bar"
        ng-class="{'saving': c.saveStatus === 'saving', 'saved': c.saveStatus === 'saved', 'error': c.saveStatus === 'error'}"
        ng-show="c.saveStatus">
        <i class="fas fa-spinner fa-spin" ng-show="c.saveStatus === 'saving'"></i>
        <i class="fas fa-check-circle" ng-show="c.saveStatus === 'saved'"></i>
        <i class="fas fa-exclamation-circle" ng-show="c.saveStatus === 'error'"></i>
        <span>{{c.saveStatusMessage}}</span>
      </div>
    </div>

    <!-- ============================================
         RIGHT PANEL — PDF VIEWER
         ============================================ -->
    <div class="pdf-panel">

      <div class="pdf-header">
        <div class="pdf-title">
          <i class="fas fa-file-pdf"></i>
          <span ng-if="c.currentDocumentLabel()">{{c.currentDocumentLabel()}}</span>
          <span ng-if="!c.currentDocumentLabel()">No document selected</span>
        </div>

        <div class="pdf-controls">
          <div class="control-group">
            <button ng-click="c.fitWidth()" ng-disabled="c.isLoading || !c.pdfLoaded" class="btn-icon"
              ng-class="{'active': c.zoomMode === 'fit-width'}" title="Fit to Width">
              <i class="fa-solid fa-arrows-left-right-to-line"></i>
            </button>
            <button ng-click="c.actual100Percent()" ng-disabled="c.isLoading || !c.pdfLoaded" class="btn-icon"
              ng-class="{'active': c.zoomMode === 'actual-size'}" title="Actual Size (100%)">
              <i class="fa-solid fa-text-height"></i>
            </button>
          </div>

          <div class="control-group">
            <button ng-click="c.previousPage()" ng-disabled="c.currentPage <= 1 || c.isLoading" class="btn-icon"
              title="Previous Page">
              <i class="fas fa-chevron-left"></i>
            </button>
            <div class="page-info">
              <span>Page {{c.currentPage}} of {{c.totalPages}}</span>
            </div>
            <button ng-click="c.nextPage()" ng-disabled="c.currentPage >= c.totalPages || c.isLoading" class="btn-icon"
              title="Next Page">
              <i class="fas fa-chevron-right"></i>
            </button>
          </div>
        </div>
      </div>

      <div class="pdf-content" id="pdfContainer">
        <div class="pdf-loading-overlay" ng-show="c.isPdfLoading">
          <div class="pdf-loader">
            <i class="fas fa-spinner fa-spin"></i>
            <span>Loading PDF...</span>
          </div>
        </div>

        <div class="pdf-placeholder" ng-show="!c.pdfLoaded && !c.isPdfLoading">
          <div class="placeholder-content">
            <i class="fas fa-file-pdf placeholder-icon"></i>
            <h3 class="placeholder-title">No Document Available</h3>
            <p class="placeholder-text">Select a property location to view its document</p>
          </div>
        </div>

        <div class="pdf-canvas-wrapper" ng-show="c.pdfLoaded">
          <canvas id="pdfCanvas" class="pdf-canvas"></canvas>
          <canvas id="annotationCanvas" class="annotation-canvas"></canvas>
        </div>
      </div>

      <div class="pdf-footer">
        <div class="footer-content">
          <span class="footer-item">
            <i class="fas fa-file"></i>
            A4: 595 × 842 points
          </span>
          <span class="footer-item">
            <i class="fas fa-expand"></i>
            Scale: {{(c.scale * 100) | number:0}}%
          </span>
          <span class="footer-item" ng-if="c.activeField">
            <i class="fas fa-crosshairs"></i>
            Active: {{c.activeField.field_name}}
          </span>
        </div>
      </div>
    </div>
  </div>
</div>
